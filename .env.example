# Copy this file to .env and fill in real values. .env is gitignored —
# never commit it.

# MikroTik REST API (RouterOS 7+, REST API enabled by default on the www service)
MIKROTIK_URL=http://192.168.1.1
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=changeme

# familink does NOT bundle a database — bring your own MariaDB/MySQL and
# point these at it. Create the database and a dedicated user yourself,
# e.g.:
#   CREATE DATABASE familink CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#   CREATE USER 'familink'@'%' IDENTIFIED BY 'a-fresh-password';
#   GRANT ALL PRIVILEGES ON familink.* TO 'familink'@'%';
# `alembic upgrade head` (run automatically on container start) creates the
# schema on first boot.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=familink
DB_USER=familink
DB_PASSWORD=changeme

# How often (seconds) the discovery loop polls MikroTik
SYNC_INTERVAL_S=60

# All timestamps are stored in UTC no matter what timezone your database
# server happens to be running in -- this only controls how they're
# DISPLAYED in the admin UI. Any IANA timezone name works.
DISPLAY_TIMEZONE=America/Sao_Paulo

# Admin panel auth (HTTP Basic). Leave ADMIN_PASSWORD empty to disable
# auth entirely -- fine for local dev, NOT recommended for anything else:
# the enforcement feature means an unauthenticated visitor can change what
# a device's real internet access is, not just relabel it in a database.
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Reserved for future phases — not consumed by the app yet (see SPEC.md):
# MQTT_BROKER_URL=mqtt://192.168.1.10:1883
# MQTT_USER=
# MQTT_PASSWORD=
